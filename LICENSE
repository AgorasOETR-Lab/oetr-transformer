# ⚙️ 4. Código base (núcleo funcional)


## 🔹 roles.py


```python

class Role:

    def __init__(self, name, function):

        self.name = name

        self.function = function



    def apply(self, x):

        return self.function(x)


🔹 rotation.py


def rotate_roles(heads, roles, step):

    assignments = {}

    for i, head in enumerate(heads):

        role_index = (i + step) % len(roles)

        assignments[head] = roles[role_index]

    return assignments


🔹 metacognition.py


def metacognitive_function(outputs):

    # Simple aggregation (expand later)

    return sum(outputs) / len(outputs)




def coherence_score(outputs):

    # Placeholder metric

    return 1.0


🔹 oetr_model.p (núcleo)

from src.rotation import rotate_roles

from src.metacognition import metacognitive_function



class OETRModel:

    def __init__(self, roles, heads):

        self.roles = roles

        self.heads = heads



    def process(self, input_data):

        all_outputs = []



        for step in range(len(self.roles)):

            assignments = rotate_roles(self.heads, self.roles, step)



            step_outputs = []

            for head, role in assignments.items():

                output = role.apply(input_data)

                step_outputs.append(output)



            all_outputs.extend(step_outputs)



        meta_output = metacognitive_function(all_outputs)

        return meta_output